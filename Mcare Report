      border: 1px solid var(--border-light);
      border-radius: 8px;
      padding: var(--space-md);
      margin-bottom: var(--space-xl);
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: var(--space-md);
