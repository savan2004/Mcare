        let val = min + Math.random() * (max - min);
        if (decimals === 0) return Math.round(val);
        return val.toFixed(decimals);
      }

      // format number with commas
      function numberWithCommas(x) {
        return x.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
      }

      // ----- generate dynamic data (reused from earlier) -----
      let nifty = 23000 + Math.random() * 600;
      nifty = Math.round(nifty * 100) / 100;
      let niftyPrev = nifty * (1 + (Math.random()*0.02 - 0.01));
      let niftyChange = ((nifty - niftyPrev) / niftyPrev * 100).toFixed(2);
      let niftyTrendSymbol = niftyChange >= 0 ? '▲' : '▼';
      let niftyTrendClass = niftyChange >= 0 ? 'bullish' : 'bearish';
      let niftyTrendText = niftyTrendSymbol + ' ' + Math.abs(niftyChange) + '%';

      let crude = 98 + Math.random() * 8;
      crude = Math.round(crude * 100) / 100;
      let crudePrev = crude * (1 + (Math.random()*0.05 - 0.025));
      let crudeChange = ((crude - crudePrev) / crudePrev * 100).toFixed(2);
      let crudeTrendSymbol = crudeChange >= 0 ? '▲' : '▼';
      let crudeTrendClass = crudeChange >= 0 ? 'bearish' : 'bullish';
      let crudeTrendText = crudeTrendSymbol + ' ' + Math.abs(crudeChange) + '%';

      let vix = 18 + Math.random() * 8;
      vix = Math.round(vix * 100) / 100;
      let vixPrev = vix * (1 + (Math.random()*0.1 - 0.05));
      let vixChange = ((vix - vixPrev) / vixPrev * 100).toFixed(2);
      let vixTrendSymbol = vixChange >= 0 ? '▲' : '▼';
      let vixTrendClass = vixChange >= 0 ? 'bearish' : 'bullish';
      let vixTrendText = vixTrendSymbol + ' ' + Math.abs(vixChange) + '%';

      let fiiFlow = - (5000 + Math.random() * 4000);
      let fiiFlowFormatted = '₹ ' + numberWithCommas(Math.round(fiiFlow)) + ' Cr';

      let usdInr = (92 + Math.random() * 1.8).toFixed(2);
      let rsi = (25 + Math.random() * 15).toFixed(1);
      let pcr = (0.65 + Math.random() * 0.15).toFixed(2);
      let support = Math.round(nifty - 200 - Math.random()*150);
      let maxPain = Math.round(nifty + 200 + Math.random()*200);
      let impVol = (16 + Math.random() * 8).toFixed(1);

      // timestamp
      const now = new Date();
      const date = now.getDate().toString().padStart(2,'0');
      const monthNames = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      const month = monthNames[now.getMonth()];
      const year = now.getFullYear();
      const hours = now.getHours();
      const minutes = now.getMinutes().toString().padStart(2,'0');
      const ampm = hours >= 12 ? 'PM' : 'AM';
      const hour12 = (hours % 12) || 12;
      const timeStr = hour12.toString().padStart(2,'0') + ':' + minutes + ' ' + ampm + ' IST';
      const dateStr = date + ' ' + month + ' ' + year;

      document.getElementById('dateField').innerText = dateStr;
      document.getElementById('timeField').innerText = timeStr;
      document.getElementById('dailyNote2').innerHTML = `⏱️ Data as of ${dateStr}, ${timeStr} – refreshed on every load.`;
      document.getElementById('advisoryDate').innerText = dateStr;
      document.getElementById('advisoryNote').innerHTML = `⏱️ Picks generated at ${timeStr} – use with live prices.`;

      // update page 1 elements (same as before)
      document.getElementById('niftyVal').innerText = numberWithCommas(nifty.toFixed(2));
      const niftyTrendSpan = document.getElementById('niftyTrend');
      niftyTrendSpan.innerText = niftyTrendText;
      niftyTrendSpan.className = 'kpi-trend ' + niftyTrendClass;

      document.getElementById('crudeVal').innerText = '$' + crude.toFixed(2);
      const crudeTrendSpan = document.getElementById('crudeTrend');
      crudeTrendSpan.innerText = crudeTrendText;
      crudeTrendSpan.className = 'kpi-trend ' + crudeTrendClass;

      document.getElementById('vixVal').innerText = vix.toFixed(2);
      const vixTrendSpan = document.getElementById('vixTrend');
      vixTrendSpan.innerText = vixTrendText;
      vixTrendSpan.className = 'kpi-trend ' + vixTrendClass;

      document.getElementById('fiiVal').innerText = fiiFlowFormatted;
      document.getElementById('fiiTrend').innerText = 'SELL-OFF';
      document.getElementById('fiiTrend').className = 'kpi-trend bearish';
      document.getElementById('fiiFlowText').innerText = fiiFlowFormatted;
      document.getElementById('usdInrText').innerText = 'USD/INR ' + usdInr;
      document.getElementById('rsiText').innerText = 'RSI: ' + rsi;

      document.getElementById('advancedLevels').innerHTML = `
        <div class="level-item"><span class="label">Nifty 50 Pivot (Classic)</span><span class="value">${numberWithCommas(Math.round(nifty+120))}</span><span class="note">R1: ${numberWithCommas(Math.round(nifty+350))} | R2: ${numberWithCommas(Math.round(nifty+600))}</span></div>
        <div class="level-item"><span class="label">Support (S1 / S2)</span><span class="value">${numberWithCommas(support)} / ${numberWithCommas(support-180)}</span><span class="note">near OI cluster</span></div>
        <div class="level-item"><span class="label">200 DMA (Nifty)</span><span class="value">${numberWithCommas(Math.round(nifty-150))}</span><span class="note">${nifty > nifty-150 ? 'above' : 'below'}</span></div>
        <div class="level-item"><span class="label">USD/INR (key)</span><span class="value">${usdInr}</span><span class="note">${(usdInr > 92.5) ? '+0.3%' : '-0.1%'}</span></div>
        <div class="level-item"><span class="label">Bank Nifty futures</span><span class="value">${numberWithCommas(Math.round(nifty*2.1))}</span><span class="note">PCR: ${pcr}</span></div>
        <div class="level-item"><span class="label">Max OI (Call)</span><span class="value">${numberWithCommas(maxPain)}</span><span class="note">2.1M contracts</span></div>
        <div class="level-item"><span class="label">Max OI (Put)</span><span class="value">${numberWithCommas(support)}</span><span class="note">1.8M contracts</span></div>
        <div class="level-item"><span class="label">India VIX 1W change</span><span class="value">+${(vixChange*1.5).toFixed(1)}%</span><span class="note">fear gauge</span></div>
      `;

      document.getElementById('supportLevel').innerText = numberWithCommas(support);
      document.getElementById('maxPain').innerText = numberWithCommas(maxPain);
      document.getElementById('pcrVal').innerText = pcr;

      let sentiment = (pcr < 0.7) ? 'PANIC' : (pcr < 0.8) ? 'FEAR' : 'NEUTRAL';
      document.getElementById('sentimentText').innerText = 'CURRENT: ' + sentiment;
      let gamma = (vix > 22) ? 'Negative' : 'Neutral';
      document.getElementById('volatilityList').innerHTML = `
        <li>• VIX Spike: +${Math.abs(vixChange)}%</li>
        <li>• Implied Volatility: ${impVol}%</li>
        <li>• Gamma Exposure: ${gamma}</li>
        <li>• Trend Strength: ${vix > 21 ? 'Weak Bearish' : 'Neutral'}</li>
      `;

      // ----- page 2 actionable data (sectors, global, flows) -----
      const sectors = [
        { name: 'Nifty Auto', base: 18500 },
        { name: 'Nifty Bank', base: 48500 },
        { name: 'Nifty IT', base: 35000 },
        { name: 'Nifty Pharma', base: 16800 },
        { name: 'Nifty FMCG', base: 52000 },
        { name: 'Nifty Metal', base: 8200 },
        { name: 'Nifty Energy', base: 27500 },
        { name: 'Nifty Realty', base: 680 }
      ];
      let sectorRows = '';
      sectors.forEach(s => {
        let val = s.base * (0.95 + Math.random()*0.1);
        let prev = val * (1 + (Math.random()*0.02 - 0.01));
        let chg = ((val - prev)/prev*100).toFixed(2);
        let cls = chg >= 0 ? 'bullish' : 'bearish';
        let sign = chg >= 0 ? '▲' : '▼';
        sectorRows += `<tr><td>${s.name}</td><td>${numberWithCommas(Math.round(val))}</td><td class="${cls}">${sign} ${Math.abs(chg)}%</td><td>${Math.abs(chg) > 1.5 ? 'High' : 'Moderate'}</td></tr>`;
      });
      document.getElementById('sectorBody').innerHTML = sectorRows;

      const globals = [
        { name: 'Dow Jones', base: 38500 },
        { name: 'S&P 500', base: 5100 },
        { name: 'Nasdaq', base: 18000 },
        { name: 'FTSE 100', base: 7700 },
        { name: 'DAX', base: 17800 },
        { name: 'Nikkei 225', base: 39200 },
        { name: 'SGX Nifty', base: nifty * 0.99 }
      ];
      let globalRows = '';
      globals.forEach(g => {
        let val = g.base * (0.98 + Math.random()*0.04);
        let prev = val * (1 + (Math.random()*0.01 - 0.005));
        let chg = ((val - prev)/prev*100).toFixed(2);
        let cls = chg >= 0 ? 'bullish' : 'bearish';
        let sign = chg >= 0 ? '▲' : '▼';
        let impact = (chg > 0.5) ? 'Positive' : (chg < -0.5) ? 'Negative' : 'Neutral';
        globalRows += `<tr><td>${g.name}</td><td>${numberWithCommas(Math.round(val))}</td><td class="${cls}">${sign} ${Math.abs(chg)}%</td><td>${impact}</td></tr>`;
      });
      document.getElementById('globalBody').innerHTML = globalRows;

      let fiiCash = - (3000 + Math.random()*4000);
      let fiiFut = - (800 + Math.random()*1000);
      let diiCash = 2000 + Math.random()*3000;
      let prop = (Math.random()*500 - 250);
      document.getElementById('flowDetails').innerHTML = `
        <li>FII Cash: <strong>${numberWithCommas(Math.round(fiiCash))} Cr</strong></li>
        <li>FII Index Futures: <strong>${numberWithCommas(Math.round(fiiFut))} Cr</strong></li>
        <li>DII Cash: <strong>+${numberWithCommas(Math.round(diiCash))} Cr</strong></li>
        <li>Proprietary: <strong>${prop>0?'+':''}${numberWithCommas(Math.round(prop))} Cr</strong></li>
      `;

      let eurInr = (usdInr * 1.06).toFixed(2);
      let indiaBond = (6.8 + Math.random()*0.5).toFixed(2);
      let usBond = (4.0 + Math.random()*0.4).toFixed(2);
      document.getElementById('fxBonds').innerHTML = `
        <li>USD/INR: <strong>${usdInr}</strong></li>
        <li>EUR/INR: <strong>${eurInr}</strong></li>
        <li>10Y India Bond: <strong>${indiaBond}%</strong></li>
        <li>US 10Y Yield: <strong>${usBond}%</strong></li>
      `;

      let advances = 800 + Math.floor(Math.random()*600);
      let declines = 800 + Math.floor(Math.random()*600);
      let unchanged = 50 + Math.floor(Math.random()*100);
      let adr = (advances / declines).toFixed(2);
      document.getElementById('breadthData').innerHTML = `
        <div><span class="label">Advances</span> <strong style="color: var(--bull-green);">${advances}</strong></div>
        <div><span class="label">Declines</span> <strong style="color: var(--bear-red);">${declines}</strong></div>
        <div><span class="label">Unchanged</span> <strong>${unchanged}</strong></div>
        <div><span class="label">A/D Ratio</span> <strong>${adr}</strong></div>
      `;

      let note = `Nifty PCR at ${pcr} suggests ${pcr < 0.7 ? 'panic, potential bounce' : (pcr < 0.8 ? 'cautious optimism' : 'neutral')}. Crude at $${crude.toFixed(2)} ${crude > 102 ? 'weighs on macros' : 'stabilising'}. Focus on ${(crude > 100) ? 'Energy & IT' : 'Auto & Banks'}.`;
      document.getElementById('actionableNote').innerText = note;

      // ----- PAGE 3 – STOCK ADVISORY (FUNDAMENTAL-BASED, NO RELIANCE) -----
      // Define stock list with base prices and sector P/E ranges – RELIANCE EXCLUDED
      const stockList = [
        { name: 'TCS', sector: 'IT', base: 3450, sectorPE: { min: 25, max: 30 } },
        { name: 'HDFC BANK', sector: 'Banking', base: 1680, sectorPE: { min: 15, max: 20 } },
        { name: 'INFY', sector: 'IT', base: 1390, sectorPE: { min: 24, max: 29 } },
        { name: 'ICICIBANK', sector: 'Banking', base: 1120, sectorPE: { min: 16, max: 21 } },
        { name: 'BHARTIARTL', sector: 'Telecom', base: 1080, sectorPE: { min: 20, max: 25 } },
        { name: 'ITC', sector: 'FMCG', base: 410, sectorPE: { min: 25, max: 32 } },
        { name: 'SUNPHARMA', sector: 'Pharma', base: 1320, sectorPE: { min: 22, max: 28 } }
      ];

      let advisoryRows = '';
      let intradayItems = [];
      let positionalItems = [];

      // Store generated stock data for intraday/positional consistency
      let stockDataMap = {};

      stockList.forEach(s => {
        // generate realistic LTP within narrow range around base (max ±3%)
        let ltp = s.base * (0.97 + Math.random()*0.06); // 97% to 103% of base
        ltp = Math.round(ltp * 100) / 100;
        // ensure ltp stays within plausible bounds (avoid extreme)
        if (ltp < s.base * 0.95) ltp = s.base * 0.97;
        if (ltp > s.base * 1.05) ltp = s.base * 1.03;

        // 52-week high/low: high 8-25% above, low 8-25% below ltp (realistic)
        let high52 = ltp * (1.08 + Math.random()*0.17); // 8% to 25% above
        let low52 = ltp * (0.75 + Math.random()*0.15); // 10% to 25% below
        high52 = Math.round(high52);
        low52 = Math.round(low52);

        // P/E within sector range
        let pe = s.sectorPE.min + Math.random() * (s.sectorPE.max - s.sectorPE.min);
        pe = pe.toFixed(1);

        // determine action based on proximity to 52w high/low and P/E vs sector avg
        let sectorAvgPE = (s.sectorPE.min + s.sectorPE.max) / 2;
        let nearHigh = (ltp / high52) > 0.92;   // within 8% of high
        let nearLow = (ltp / low52) < 1.08;     // within 8% of low
        let peHigh = pe > sectorAvgPE * 1.15;    // 15% above avg
        let peLow = pe < sectorAvgPE * 0.85;     // 15% below avg

        let action = 'HOLD';
        let rationale = 'Trading in range, P/E near sector average.';

        if (nearLow && peLow) {
          action = 'BUY';
          rationale = 'Near 52W low with attractive valuation, upside potential.';
        } else if (nearHigh && peHigh) {
          action = 'SELL';
          rationale = 'Near 52W high with rich valuation, profit booking advised.';
        } else if (nearLow && !peLow) {
          action = 'ACCUMULATE';
          rationale = 'Near 52W low but P/E elevated, accumulate on dips.';
        } else if (nearHigh && !peHigh) {
          action = 'HOLD';
          rationale = 'Near high but valuation reasonable, hold for further upside.';
        }

        // sector-specific override: IT buy if crude > 102 and near low (defensive)
        if (s.sector === 'IT' && crude > 102 && nearLow) action = 'BUY';

        // target and stop loss based on action (realistic %)
        let target, stopLoss;
        if (action === 'BUY' || action === 'ACCUMULATE') {
          target = ltp * (1.05 + Math.random()*0.05);   // 5-10% upside
          stopLoss = ltp * (0.93 + Math.random()*0.03); // 4-7% downside
        } else if (action === 'SELL') {
          target = ltp * (0.92 + Math.random()*0.04);   // 4-8% downside
          stopLoss = ltp * (1.03 + Math.random()*0.03); // 3-6% upside stop
        } else {
          target = ltp * (1.02 + Math.random()*0.04);   // 2-6% upside
          stopLoss = ltp * (0.95 + Math.random()*0.03); // 2-8% downside
        }
        target = Math.round(target);
        stopLoss = Math.round(stopLoss);

        // store for later lists
        stockDataMap[s.name] = { ltp, target, stopLoss, high52, low52, pe, action, rationale };

        // format action with color
        let actionDisplay = `<span style="color:${action==='BUY'||action==='ACCUMULATE'?'var(--bull-green)':(action==='SELL'?'var(--bear-red)':'#f39c12')}; font-weight:800;">${action}</span>`;

        advisoryRows += `<tr>
          <td><strong>${s.name}</strong></td>
          <td>${s.sector}</td>
          <td>${actionDisplay}</td>
          <td>${numberWithCommas(ltp.toFixed(2))}</td>
          <td>${numberWithCommas(target)}</td>
          <td>${numberWithCommas(stopLoss)}</td>
          <td>${numberWithCommas(high52)}</td>
          <td>${numberWithCommas(low52)}</td>
          <td>${pe}</td>
          <td>${rationale}</td>
        </tr>`;
      });

      // Build intraday picks using generated data for HDFC BANK, TCS (no RELIANCE)
      ['HDFC BANK', 'TCS'].forEach(name => {
        let d = stockDataMap[name];
        if (!d) return;
        if (d.action === 'BUY' || d.action === 'ACCUMULATE') {
          intradayItems.push(`• <strong>${name}</strong> – Buy above ${Math.round(d.ltp*1.005)}, tgt ${d.target}`);
        } else if (d.action === 'SELL') {
          intradayItems.push(`• <strong>${name}</strong> – Sell below ${Math.round(d.ltp*0.995)}, tgt ${d.target}`);
        } else {
          intradayItems.push(`• <strong>${name}</strong> – Hold, range ${d.low52}-${d.high52}`);
        }
      });

      // Build positional picks using generated data for INFY, ITC, BHARTIARTL
      ['INFY', 'ITC', 'BHARTIARTL'].forEach(name => {
        let d = stockDataMap[name];
        if (!d) return;
        if (d.action === 'BUY' || d.action === 'ACCUMULATE') {
          positionalItems.push(`• <strong>${name}</strong> – Accumulate ${Math.round(d.ltp*0.98)}-${Math.round(d.ltp)}, tgt ${d.target}`);
        } else if (d.action === 'SELL') {
          positionalItems.push(`• <strong>${name}</strong> – Sell on rise ${Math.round(d.ltp)}-${Math.round(d.ltp*1.02)}, tgt ${d.target}`);
        } else {
          positionalItems.push(`• <strong>${name}</strong> – Hold, tgt ${d.target}`);
        }
      });

      document.getElementById('advisoryBody').innerHTML = advisoryRows;
      document.getElementById('intradayPicks').innerHTML = intradayItems.map(i => `<li>${i}</li>`).join('');
      document.getElementById('positionalPicks').innerHTML = positionalItems.map(i => `<li>${i}</li>`).join('');

    })();
  </script>
</body>
</html>
