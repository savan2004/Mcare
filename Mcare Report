    .stress-alert {
      border: 1px solid var(--bear-red);
      background: #fff5f5;
      padding: var(--space-md);
      border-radius: 6px;
      margin: var(--space-lg) 0;
    }

    .stress-alert strong {
      color: var(--bear-red);
      font-size: var(--fs-small);
    }

    /* QR */
    .qr-sim {
      margin-top: var(--space-xl);
      border: 2px dashed var(--gold);
      padding: var(--space-lg);
      text-align: center;
      background: #fefaf2;
    }

    .qr-sim span {
      font-size: var(--fs-micro);
      color: var(--navy);
      letter-spacing: 2px;
    }
    .qr-sim div {
      font-weight: 800;
      font-size: 1.1rem;
      color: var(--gold);
      letter-spacing: 5px;
      margin-top: var(--space-xs);
    }

    /* footer (absolute within page) */
    .report-footer {
      position: absolute;
      bottom: 12mm;            /* adjusted for 15mm padding */
      left: 15mm;
      right: 15mm;
      border-top: 1px solid var(--border-light);
      padding-top: var(--space-sm);
      display: flex;
      justify-content: space-between;
      font-size: var(--fs-micro);
      color: #95a5a6;
      font-family: 'Helvetica', sans-serif;
