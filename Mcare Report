    /* print button */
    .print-toolbar {
      text-align: right;
      margin: 10px auto;
      max-width: var(--print-page-width);
      padding: 0 15px;
    }
    .print-btn {
      background: var(--navy);
      color: white;
      border: none;
      padding: 10px 24px;
      font-size: 1rem;
      font-family: 'Helvetica', sans-serif;
