      .report-footer {
        bottom: 12mm;
        left: 15mm;
        right: 15mm;
      }
      .badge, th {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }

    /* responsive */
    @media (max-width: 700px) {
      :root {
        --fs-brand: 1.8rem;
        --print-padding: 10mm 10mm;
      }
      .kpi-grid {
        grid-template-columns: repeat(2, 1fr);
