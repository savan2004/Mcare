    :root {
      --navy: #001f3f;
      --gold: #b38b4d;
      --bear-red: #c0392b;
      --bull-green: #27ae60;
      --soft-bg: #f8f9fa;
      --border-light: #d1d8e0;
      --text-dark: #2c3e50;
      --text-muted: #5d6d7e;

      --fs-micro: 0.7rem;    
      --fs-small: 0.8rem;     
      --fs-body: 0.95rem;     
      --fs-h2: 1.3rem;        
      --fs-brand: 2.2rem;     

      --space-xs: 0.25rem;
      --space-sm: 0.5rem;
      --space-md: 1rem;
      --space-lg: 1.5rem;
      --space-xl: 2rem;

      --print-page-width: 210mm;
      --print-page-min-height: 297mm;
      --print-padding: 15mm 15mm;  /* symmetric 15mm margins for perfect A4 print */
    }

    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      background: #e9ecef;
      color: var(--text-dark);
      line-height: 1.5;
      padding: 0;  /* body padding removed for print consistency */
      margin: 0;
    }

    .page {
      max-width: var(--print-page-width);
      margin: 10mm auto;        /* screen only, ignored in print */
      background: white;
      box-shadow: 0 12px 30px rgba(0,0,0,0.1);
      padding: var(--print-padding);
      min-height: var(--print-page-min-height);
      position: relative;
      box-sizing: border-box;
      border-radius: 4px 4px 0 0;
      page-break-after: always;  /* ensures each page starts on new sheet */
    }

    /* header */
    .report-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      border-bottom: 4px solid var(--navy);
      padding-bottom: var(--space-sm);
      margin-bottom: var(--space-lg);
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .brand h1 {
      font-size: var(--fs-brand);
      font-weight: 900;
      color: var(--navy);
      letter-spacing: -1.5px;
      line-height: 1.1;
      margin: 0;
    }

    .brand span {
      display: block;
      color: var(--gold);
      font-size: var(--fs-micro);
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-family: 'Helvetica', 'Arial', sans-serif;
    }

    .meta {
      text-align: right;
      font-family: 'Helvetica', 'Arial', sans-serif;
      font-size: var(--fs-small);
      color: var(--text-muted);
    }

    .meta strong {
      color: var(--navy);
      font-weight: 700;
    }

    /* KPI grid (4 cols) */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-md);
      margin-bottom: var(--space-xl);
    }

    .kpi-card {
      border: 1px solid var(--border-light);
      background: var(--soft-bg);
      padding: var(--space-md) var(--space-sm);
      text-align: center;
      border-radius: 6px;
    }

    .kpi-label {
      font-size: var(--fs-micro);
      text-transform: uppercase;
      color: var(--text-muted);
      font-weight: 700;
      letter-spacing: 0.3px;
      display: block;
      margin-bottom: var(--space-xs);
    }

    .kpi-value {
      font-size: 1.4rem;
      font-weight: 900;
      color: var(--navy);
      font-family: 'Helvetica', 'Arial', sans-serif;
      line-height: 1.2;
    }

    .kpi-trend {
      font-size: var(--fs-micro);
      font-weight: 700;
      margin-top: var(--space-xs);
    }

    /* section headings */
    h2 {
